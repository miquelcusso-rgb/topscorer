{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/refresh-rumors",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/generate-polls",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/resolve-picks",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/cron/performance-alerts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/fantasy-recompute",
      "schedule": "0 5 * * *"
    }
  ]
}
